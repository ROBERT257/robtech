# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Settings
DB_NAME=rotech
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# M-Pesa Daraja API Settings
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-passkey
MPESA_SHORTCODE=174379
MPESA_ENVIRONMENT=sandbox
MPESA_CALLBACK_URL=https://your-public-domain.com/api/payments/callback/

# M-Pesa is the only supported payment provider.
PAYMENT_PROVIDER=mpesa

# CORS Settings
CORS_ALLOWED_ORIGINS=http://localhost:8081,exp://127.0.0.1:8081

# Expo app API base URL
# Use your computer's LAN IP for a physical phone, for example:
# EXPO_PUBLIC_API_URL=http://192.168.1.50:8081/api
